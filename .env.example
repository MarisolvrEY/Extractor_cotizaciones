# ============================================================
# PASO 1 — Azure AI Content Understanding (OCR)
# ============================================================
# Endpoint de tu recurso en Azure AI Foundry:
#   https://<resource-name>.services.ai.azure.com/
AZURE_OCR_ENDPOINT=https://<resource-name>.services.ai.azure.com/
AZURE_OCR_KEY=<your-azure-ocr-key>

# Analyzer: prebuilt-read (texto), prebuilt-layout (tablas), prebuilt-document (campos)
AZURE_OCR_ANALYZER=prebuilt-read
AZURE_OCR_API_VERSION=2024-11-30

# ============================================================
# PASO 3 — Azure AI Foundry LLM
# ============================================================
# Endpoint del modelo desplegado en AI Foundry
# Azure OpenAI:   https://<resource>.openai.azure.com/
# Serverless:     https://<endpoint>.inference.ai.azure.com/
# Pega aquí el Target URI exacto que ves en AI Foundry → Models + endpoints
# Ejemplo AI Foundry Project:
#   https://xxx.azure.com/api/projects/mi-proyecto/openai/v1/responses
# Ejemplo Azure OpenAI clásico:
#   https://mi-recurso.openai.azure.com/
AZURE_LLM_ENDPOINT=https://<pega-aqui-el-target-uri>
AZURE_LLM_KEY=<your-azure-llm-key>
AZURE_LLM_DEPLOYMENT=gpt-4o-mini
AZURE_LLM_API_VERSION=2024-12-01-preview
AZURE_LLM_MAX_TOKENS=2000
AZURE_LLM_TEMPERATURE=0.0

# ============================================================
# PATHS (opcionales — tienen defaults)
# ============================================================
INPUT_DIR=data/input
PROCESABLES_DIR=data/procesables
COTIZACIONES_DIR=data/cotizaciones_encontradas
OUTPUT_OCR_DIR=data/output/json
OUTPUT_CAMPOS_DIR=data/output/campos
OUTPUT_METADATOS_DIR=data/output/metadatos
METADATA_XLSX_NAME=metadata
OUTPUT_TABLES_DIR=data/output/tables
PROMPTS_DIR=prompts

# ============================================================
# GENERAL
# ============================================================
MAX_FILE_SIZE_MB=50
LOG_LEVEL=INFO
